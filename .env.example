RETOS_ENV=development
RETOS_API_HOST=0.0.0.0
RETOS_API_PORT=8000
RETOS_DATABASE_URL=postgresql+asyncpg://retos:retos@postgres:5432/retos
RETOS_CELERY_BROKER_URL=amqp://retos:retos@rabbitmq:5672//
RETOS_CELERY_RESULT_BACKEND=rpc://
RETOS_POSTGRES_PASSWORD=retos
RETOS_RABBITMQ_PASSWORD=retos
RETOS_JWT_SECRET=change-this-development-secret-at-least-32-chars
RETOS_JWT_ISSUER=retos
RETOS_JWT_AUDIENCE=retos-api
RETOS_BOOTSTRAP_ADMIN_EMAIL=admin@retos.dev
RETOS_BOOTSTRAP_ADMIN_PASSWORD=retos-dev-admin-change-me
RETOS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
RETOS_STORAGE_ROOT=/var/lib/retos/storage
RETOS_INDEX_ROOT=/var/lib/retos/index
RETOS_EVAL_DATASET_ROOT=/var/lib/retos/evals/datasets
RETOS_EVAL_REPORT_ROOT=/var/lib/retos/evals/reports
RETOS_PROVIDER=local
RETOS_MODEL=ollama:gemma4
RETOS_AGENT_RUNTIME=deterministic
RETOS_OLLAMA_MODEL=gemma4
RETOS_OLLAMA_BASE_URL=http://ollama:11434
RETOS_ALLOW_PAID_LLM=false
RETOS_OPENAI_MODEL=gpt-5-mini
# RETOS_OPENAI_API_KEY=
RETOS_ANTHROPIC_MODEL=claude-sonnet-4-5
# RETOS_ANTHROPIC_API_KEY=
RETOS_GOOGLE_MODEL=gemini-2.5-flash
# RETOS_GOOGLE_API_KEY=
RETOS_OPENROUTER_MODEL=openai/gpt-5-mini
# RETOS_OPENROUTER_API_KEY=
# RETOS_AZURE_OPENAI_ENDPOINT=
# RETOS_AZURE_OPENAI_DEPLOYMENT=
# RETOS_AZURE_OPENAI_API_KEY=
